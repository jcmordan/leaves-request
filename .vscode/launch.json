{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Core Debugger (launch)",
      "type": "coreclr",
      "request": "launch",
      "program": "${command:dotrush.activeTargetPath}",
      "preLaunchTask": "dotrush: Build"
    },
    {
      "name": "LeaveManagement.Api (Standard)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/backend/src/LeaveManagement.Api/bin/Debug/net10.0/LeaveManagement.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/backend/src/LeaveManagement.Api",
      "console": "internalConsole",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5148"
      },
      "launchWebBrowser": false
    }
  ]
}
